{
    "family": "nutritrack-task",
    "networkMode": "awsvpc",
    "containerDefinitions": [
        {
            "name": "nutritrack-app",
            "image": "oumaymaaaaaaaa/nutritrack-app:latest",
            "portMappings": [{ "containerPort": 8000, "hostPort": 8000, "protocol": "tcp" }],
            "essential": true,
            "environment": [
                { "name": "POSTGRES_HOST", "value": "localhost" },
                { "name": "POSTGRES_DB", "value": "nutritrack_db" },
                { "name": "POSTGRES_USER", "value": "admin" },
                { "name": "POSTGRES_PASSWORD", "value": "pass123" }
            ]
        },
        {
            "name": "postgres-db",
            "image": "postgres:15",
            "essential": true,
            "environment": [
                { "name": "POSTGRES_DB", "value": "nutritrack_db" },
                { "name": "POSTGRES_USER", "value": "admin" },
                { "name": "POSTGRES_PASSWORD", "value": "pass123" }
            ]
        }
    ],
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "512", 
    "memory": "1024",
    "executionRoleArn": "LabRole",
    "taskRoleArn": "LabRole"
}